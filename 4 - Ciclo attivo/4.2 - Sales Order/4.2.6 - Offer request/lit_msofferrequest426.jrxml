	<subDataset name="FinitureDataset" uuid="33e3b1df-14bc-4be4-b20b-adb4bdcf082e">
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="idempiereDb (dev)"/>
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<parameter name="RECORD_ID" class="java.lang.Integer"/>
		<queryString language="SQL">
			<![CDATA[SELECT
	value AS finish_code,
	name AS finish_name
FROM lit_msfinish
WHERE lit_msfinish_id IN (
	SELECT DISTINCT lit_msfinish_id
	FROM lit_msofferrequestline l
	JOIN lit_msofferrequest r ON l.lit_msofferrequest_id = r.lit_msofferrequest_id
	WHERE r.lit_msofferrequest_id = $P{RECORD_ID}
)
ORDER BY value]]>
		</queryString>
		<field name="finish_code" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="finish_code"/>
			<property name="com.jaspersoft.studio.field.label" value="finish_code"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="lit_msfinish"/>
		</field>
		<field name="finish_name" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="finish_name"/>
			<property name="com.jaspersoft.studio.field.label" value="finish_name"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="lit_msfinish"/>
		</field>
	</subDataset>
	<parameter name="RECORD_ID" class="java.lang.Integer"/>
	<parameter name="LOCALE_CODE" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[$P{REPORT_LOCALE}.toString()]]></defaultValueExpression>
	</parameter>
	<parameter name="PORTRAIT_HEADER_IMAGE" class="java.io.InputStream"/>
	<parameter name="DATE_FORMAT" class="java.lang.String">
		<defaultValueExpression><![CDATA["yyyy-MM-dd"]]></defaultValueExpression>
	</parameter>
	<parameter name="TIME_FORMAT" class="java.lang.String">
		<defaultValueExpression><![CDATA["HH:mm"]]></defaultValueExpression>
	</parameter>
	<parameter name="PORTRAIT_FOOTER_IMAGE" class="java.io.InputStream"/>
	<queryString language="SQL">
		<![CDATA[SELECT
	r.value AS request_no,
	r.created AS created,
	r.datepromised AS delivery_date,
	bp.name AS bpartner,
	r.name AS details,
	r.address1 AS address,
	r.city,
	p.name AS province,
	COALESCE(ctrl.name, c.name) AS country,
	r.postal AS zip,
	r.description AS customer_notes,
	r.help AS commercial_notes,
	l.lit_msofferrequestlinetype AS type,
	l.value AS product_code,
	f.value AS finish,
	l.name AS line_desc,
	l.qty AS qty,
	UPPER(COALESCE(utrl.uomsymbol, u.uomsymbol)) AS uom,
	l.lit_msdimension AS special_dim,
	lit_msnomwidth AS nominal_length,
	lit_msnomheight AS nominal_height,
	lit_msnomdepth AS nominal_depth,
	lit_width AS real_length,
	lit_height AS real_height,
	lit_depth AS real_depth,
	CASE l.lit_msofferrequestlinetype
		WHEN 'P' THEN COALESCE(msp.lit_mscontqty, 0)
		ELSE null
	END AS standard_qty,
	r.weight AS weight
FROM lit_msofferrequest r
LEFT JOIN lit_msofferrequestline l ON l.lit_msofferrequest_id = r.lit_msofferrequest_id
LEFT JOIN c_bpartner bp ON bp.c_bpartner_id = r.c_bpartner_id
LEFT JOIN lit_msfinish f ON f.lit_msfinish_id = l.lit_msfinish_id
LEFT JOIN c_uom u ON u.c_uom_id = l.c_uom_id
LEFT JOIN c_uom_trl utrl ON utrl.c_uom_id = u.c_uom_id AND utrl.ad_language = $P{LOCALE_CODE}
LEFT JOIN lit_mspackagingqty msp ON msp.m_product_id = l.m_product_id AND
	CASE l.lit_msdimension
		WHEN 'L' THEN l.lit_width BETWEEN msp.lit_msminlimit AND msp.lit_msmaxlimit
		WHEN 'H' THEN l.lit_height BETWEEN msp.lit_msminlimit AND msp.lit_msmaxlimit
		WHEN 'P' THEN l.lit_depth BETWEEN msp.lit_msminlimit AND msp.lit_msmaxlimit
		ELSE true
	END
LEFT JOIN c_country c ON c.c_country_id = r.c_country_id
LEFT JOIN c_country_trl ctrl ON ctrl.c_country_id = c.c_country_id AND ctrl.ad_language = $P{LOCALE_CODE}
LEFT JOIN c_region p ON p.c_region_id = r.c_region_id
WHERE r.lit_msofferrequest_id =  $P{RECORD_ID}
ORDER BY l.line]]>
	</queryString>
