	<queryString>
		<![CDATA[select
    c_currency.iso_code AS c_currency_iso_code,
	ad_sysconfig.help as ad_sysconfig_help,
	ad_orginfo.lit_report_param as ad_orginfo_lit_report_param,
	ad_orginfo.lit_report_param1 as ad_orginfo_lit_report_param1,
	io.m_inout_id,
	io.created as m_inout_created,
	io.documentno as m_inout_documentno,
	io.movementdate as m_inout_movementdate,
	io.poreference as m_inout_poreference,
	io.volume as m_inout_volume,
	io.ad_client_id as m_inout_ad_client_id,
	io.dateacct as m_inout_dateacct,
	io.dateordered as m_inout_dateordered,
	io.ref_inout_id as m_inout_ref_inout_id,
	io.m_inout_id as m_inout_m_inout_id,
	io.weight as m_inout_weight,
	io.lit_grossweight as m_inout_lit_grossweight,
	coalesce(io.weight, io.lit_grossweight) as m_inout_grossweight,
	io.shipdate as m_inout_shipdate,
	io.description as m_inout_description,
	io.lit_externalaspect as m_inout_lit_externalaspect,
	io.docstatus as m_inout_docstatus,
	coalesce(io.nopackages , c_order.nopackages)as m_inout_nopackages,
	io.movementtype as m_inout_movementtype,
	io.lit_fob_notes as m_inout_lit_fob_notes,
	io.deliveryviarule as m_inout_deliveryviarule_key,
	iol.description as m_inoutline_description,
	iol.movementqty as m_inoutline_movementqty,
	iol.name as m_inoutline_name,
	iol.help as m_inoutline_help,
	iol_product.name as m_product_name,
	iol_product.producttype as m_product_producttype,
	iol_product.help as m_product_help,
	iol_product.value as m_product_value,
	iol_product.description as m_product_description,
	coalesce(iol_uom_trl.uomsymbol, iol_uom.uomsymbol) as c_uom_trl_uomsymbol,
	iol_uom_trl.name as c_uom_trl_name,
	iol_asi.lit_mslegacycode as lit_mslegacycode,
	iol_c_orderline.priceactual as c_orderline_priceactual,
	c_bpartner.name as c_bpartner_name,
	io.bpname as shipto_bpname,
	c_bpartner.lit_taxid as c_bpartner_lit_taxid,
	c_bpartner.taxid as c_bpartner_taxid,
	c_bpartner.value as c_bpartner_value,
	c_bpartner.lit_bpreport_param as c_bpartner_lit_bpreportparam,
	c_location.address1 as c_location_address1,
	c_location.postal as c_location_postal,
	c_location.city as c_location_city,
	c_bpartner_location.isbillto as c_bpartner_location_isbillto,
	c_bpartner_location.phone as c_bpartner_location_phone,
	c_bpartner_location.fax as c_bpartner_location_fax,
	c_bpartner_location.email as c_bpartner_location_email,
	c_bpartner.lit_bpreport_param as c_bpartner_lit_bpreport_param,
	c_location.regionname as c_location_regionname,
	c_bpartner.c_bpartner_id as c_bpartner_c_bpartner_id,
	c_country_trl.name as c_country_trl_name,
	c_doctype_trl.name as c_doctype_trl_name,
	coalesce(c_doctype_trl.printname, c_doctype.printname) as c_doctype_trl_printname,
	coalesce(c_doctype_trl.documentnote, c_doctype.documentnote) as c_doctype_trl_documentnote,
	c_doctype.name as c_doctype_name,
	c_doctype.printname as c_doctype_printname,
	coalesce(ad_ref_list_trl_b.name, ad_ref_list_b.name) as m_inout_fob,
	coalesce(ad_ref_list_trl_a.name, ad_ref_list_a.name) as m_inout_deliveryviarule,
	ad_ref_list_trl_a.name as m_inout_deliveryviarule_trl,
	c_bpartner_location_a.phone as c_bpartner_location_a_phone,
	c_bpartner_location_a.fax as c_bpartner_location_a_fax,
	c_bpartner_location_a.email as c_bpartner_location_a_email,
	c_bpartner_location_a.ispreservecustomname as c_bpartner_location_ispreservecustomname,
	coalesce(io.address1, c_location_a.address1) as c_location_a_address1,
	coalesce(io.address2, c_location_a.address2) as c_location_a_address2,
	c_location_a.city as c_location_a_city,
	c_bpartner_location_a.name as c_bpartner_location_a_name,
	c_location_a.postal as c_location_a_postal,
	c_location_a.regionname as c_location_a_regionname,
	c_country_trl_a.name as c_country_trl_a_name,
	m_shipper.name as m_shipper_name,
	ad_user.name as salesrep_name,
	lit_m_movementtype.name as lit_m_movementtype_name,
	c_bpartner_location_b.email as c_bpartner_location_b_email,
	c_bpartner_location_b.fax as c_bpartner_location_b_fax,
	c_bpartner_location_b.isbillto as c_bpartner_location_b_isbillto,
	c_bpartner_location_b.phone as c_bpartner_location_b_phone,
	c_location_b.address1 as c_location_b_address1,
	c_location_b.city as c_location_b_city,
	c_location_b.postal as c_location_b_postal,
	c_location_b.regionname as c_location_b_regionname,
	c_country_trl_b.name as c_country_trl_b_name,
	c_bpartner.ad_language,
	lit_tables_trl.name as m_inout_packagetype,
	lit_tables_trl_a.name as m_inout_freightcost,
	c_order.shipdate as c_order_shipdate,
	c_order.documentno as c_order_documentno,
	c_order.poreference as c_order_poreference,
	io.c_order_id as m_inout_c_order_id,
	c_order.grandtotal as c_order_grandtotal,
	c_order.discount as c_order_netdiscount,
	c_order_paymentterm.discount as c_paymentterm_discount,
	c_order.paymentrule as c_order_paymentrule,
	coalesce(c_doctype_order_trl.name, c_doctype_order.name) as c_doctype_order_trl_name,
	coalesce(ad_ref_list_trl_pr.name , ad_ref_list_pr.name) as ad_ref_list_trl_pr_name,
	coalesce(c_order_paymentterm_trl.name, c_order_paymentterm.name) as c_order_paymentterm_trl_name,
	c_order.grandtotal - c_order.grandtotal / 100::numeric * c_order_paymentterm.discount as totalnetdiscount,
	lit_attribute_v.lot as lit_attribute_v_lot
from
	m_inout io
inner join m_inoutline iol on
	iol.m_inout_id = io.m_inout_id
left join m_product iol_product on
	iol_product.m_product_id = iol.m_product_id
left join m_attributesetinstance iol_asi on
	iol_asi.m_attributesetinstance_id = iol.m_attributesetinstance_id
left join c_orderline iol_c_orderline on
	iol_c_orderline.c_orderline_id = iol.c_orderline_id
LEFT JOIN c_currency c_currency ON iol_c_orderline.c_currency_id = c_currency.c_currency_id
left join c_uom iol_uom on
	iol_product.c_uom_id = iol_uom.c_uom_id
left join c_uom_trl iol_uom_trl on
	iol_product.c_uom_id = iol_uom_trl.c_uom_id
	and iol_uom_trl.ad_language::text = $P{LOCALE_CODE}
left join ad_sysconfig ad_sysconfig on
	io.ad_client_id = ad_sysconfig.ad_client_id
	and io.ad_org_id = ad_sysconfig.ad_org_id
left join ad_user ad_user on
	io.salesrep_id = ad_user.ad_user_id
left join ad_client ad_client on
	io.ad_client_id = ad_client.ad_client_id
left join c_order c_order on
	c_order.c_order_id = io.c_order_id
left join ad_orginfo ad_orginfo on
	io.ad_org_id = ad_orginfo.ad_org_id
left join lit_attribute_v lit_attribute_v on
	iol.m_inoutline_id = lit_attribute_v.m_inoutline_id
left join ad_image ad_image on
	ad_orginfo.lit_banner_id = ad_image.ad_image_id
left join ad_image ad_image_a on
	ad_orginfo.logo_id = ad_image_a.ad_image_id
left join ad_image ad_image_b on
	ad_orginfo.lit_banner2_id = ad_image_b.ad_image_id
left join m_shipper m_shipper on
	io.m_shipper_id = m_shipper.m_shipper_id
left join lit_m_movementtype lit_m_movementtype on
	io.lit_m_movementtype_id = lit_m_movementtype.lit_m_movementtype_id
left join c_paymentterm c_order_paymentterm on
	c_order.c_paymentterm_id = c_order_paymentterm.c_paymentterm_id
left join c_paymentterm_trl c_order_paymentterm_trl on
	c_order_paymentterm_trl.c_paymentterm_id = c_order.c_paymentterm_id
	and c_order_paymentterm_trl.ad_language = $P{LOCALE_CODE}
left join c_bpartner c_bpartner on
	io.c_bpartner_id = c_bpartner.c_bpartner_id
left join c_bpartner_location c_bpartner_location on
	c_bpartner.c_bpartner_id = c_bpartner_location.c_bpartner_id
left join c_location c_location on
	c_bpartner_location.c_location_id = c_location.c_location_id
left join c_country_trl c_country_trl on
	c_location.c_country_id = c_country_trl.c_country_id
	and (c_country_trl.ad_language::text = $P{LOCALE_CODE})
left join c_doctype c_doctype on
	io.c_doctype_id = c_doctype.c_doctype_id
left join c_doctype_trl c_doctype_trl on
	c_doctype.c_doctype_id = c_doctype_trl.c_doctype_id
	and (c_doctype_trl.ad_language::text = $P{LOCALE_CODE})
left join c_doctype c_doctype_order on
	c_order.c_doctype_id = c_doctype_order.c_doctype_id
left join c_doctype_trl c_doctype_order_trl on
	c_doctype_order.c_doctype_id = c_doctype_order_trl.c_doctype_id
	and (c_doctype_order_trl.ad_language::text = $P{LOCALE_CODE})
left join ad_ref_list ad_ref_list_a on
	io.deliveryviarule = ad_ref_list_a.value::bpchar
left join ad_ref_list_trl ad_ref_list_trl_a on
	ad_ref_list_a.ad_ref_list_id = ad_ref_list_trl_a.ad_ref_list_id
	and (ad_ref_list_trl_a.ad_language::text = $P{LOCALE_CODE})
left join ad_ref_list ad_ref_list_pr on
	ad_ref_list_pr.value = c_order.paymentrule
	and ad_ref_list_pr.ad_reference_id = 195
left join ad_ref_list_trl ad_ref_list_trl_pr on
	ad_ref_list_pr.ad_ref_list_id = ad_ref_list_trl_pr.ad_ref_list_id
	and ad_ref_list_trl_pr.ad_language = $P{LOCALE_CODE}
left join ad_ref_list ad_ref_list_b on
	io.fob::text = ad_ref_list_b.value::bpchar::text
left join ad_ref_list_trl ad_ref_list_trl_b on
	ad_ref_list_b.ad_ref_list_id = ad_ref_list_trl_b.ad_ref_list_id
	and (ad_ref_list_trl_b.ad_language::text = $P{LOCALE_CODE})
left join c_bpartner_location c_bpartner_location_a on
	io.c_bpartner_location_id = c_bpartner_location_a.c_bpartner_location_id
left join c_location c_location_a on
	c_bpartner_location_a.c_location_id = c_location_a.c_location_id
left join c_country_trl c_country_trl_a on
	c_location_a.c_country_id = c_country_trl_a.c_country_id
	and (c_country_trl_a.ad_language::text = $P{LOCALE_CODE})
left join lit_tables_trl lit_tables_trl on
	io.lit_packagetype_id = lit_tables_trl.lit_tables_id
	and (lit_tables_trl.ad_language::text = $P{LOCALE_CODE})
left join lit_tables_trl lit_tables_trl_a on
	io.lit_freightcost_id = lit_tables_trl_a.lit_tables_id
	and (lit_tables_trl_a.ad_language::text = $P{LOCALE_CODE})
left join c_bpartner c_bpartner_b on
	m_shipper.c_bpartner_id = c_bpartner_b.c_bpartner_id
left join c_bpartner_location c_bpartner_location_b on
	c_bpartner_b.c_bpartner_id = c_bpartner_location_b.c_bpartner_id
left join c_location c_location_b on
	c_bpartner_location_b.c_location_id = c_location_b.c_location_id
left join c_country_trl c_country_trl_b on
	c_location_b.c_country_id = c_country_trl_b.c_country_id
	and (c_country_trl_b.ad_language::text = $P{LOCALE_CODE})
where
	(c_bpartner_location.isbillto = 'Y'::bpchar
		or c_bpartner_location.isbillto is null)
	and (c_bpartner_location_b.isbillto = 'Y'::bpchar
		or c_bpartner_location_b.isbillto is null)
	and (ad_ref_list_a.ad_reference_id = 152::numeric
		or ad_ref_list_a.ad_reference_id is null)
	and (ad_ref_list_b.ad_reference_id = 200030::numeric
		or ad_ref_list_b.ad_reference_id is null)
	and (ad_sysconfig.name::text = 'LIT_REP_DDTSO'::text
		or ad_sysconfig.name is null)
	and io.m_inout_id = $P{RECORD_ID}]]>
	</queryString>
