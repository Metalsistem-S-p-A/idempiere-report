	<queryString>
		<![CDATA[SELECT
(
  SELECT COALESCE(SUM(fa.amtacctdr - fa.amtacctcr), 0)
  FROM fact_acct fa
  WHERE fa.ad_client_id = fact_acct.ad_client_id
    AND fa.ad_org_id = fact_acct.ad_org_id
    AND fa.account_id = fact_acct.account_id
    AND fa.postingtype = 'A'
    AND fa.dateacct < $P{DateAcctFrom}
) AS beginningbalance,
     fact_acct."dateacct" AS fact_acct_dateacct,
     fact_acct."description" AS fact_acct_description,
     fact_acct."amtacctcr" AS fact_acct_amtacctcr,
     fact_acct."amtacctdr" AS fact_acct_amtacctdr,
fact_acct."fact_acct_id" AS fact_acct_id,
     fact_acct."ad_table_id" AS fact_acct_ad_table_id,
     fact_acct."ad_client_id" AS fact_acct_ad_client_id,
     fact_acct."seqno" AS fact_acct_seqno,
     ad_client."name" AS ad_client_name,
     c_bpartner."name" AS c_bpartner_name,
     fact_acct."account_id" AS fact_acct_account_id,
     fact_acct."datetrx" AS fact_acct_datetrx,
     ev.name AS element_name,
     ev.value AS element_value,
case
	when fact_acct.ad_table_id=224
  	then jou.documentno
	when fact_acct.ad_table_id=318
	then inv.documentno
	when fact_acct.ad_table_id=319
	then inout.documentno
	when fact_acct.ad_table_id=321 
    then tory.documentno
    when fact_acct.ad_table_id=323
     then mov.documentno
     when fact_acct.ad_table_id=325
     then prod.documentno
     when fact_acct.ad_table_id=335 
     then pay.documentno
     when fact_acct.ad_table_id=472
     then match.documentno
     when fact_acct.ad_table_id=735
     then hdr.documentno
	else ' '
	END as documentno,
(select coalesce(b.name, a.name) from ad_table a left join ad_table_trl b on a.ad_table_id = b.ad_table_id and b.ad_language = $P{LOCALE_CODE} where a.ad_table_id = fact_acct.ad_table_id) as TipoDoc,
	 c_currency.iso_code,
	 inv.vatdocumentno
FROM
    "adempiere"."fact_acct" fact_acct 
    INNER JOIN c_currency ON fact_acct.c_currency_id = c_currency.c_currency_id
	LEFT OUTER JOIN "adempiere"."ad_client" ad_client ON fact_acct."ad_client_id" = ad_client."ad_client_id"
	LEFT OUTER JOIN "adempiere"."c_bpartner" c_bpartner ON fact_acct."c_bpartner_id" = c_bpartner."c_bpartner_id"
	LEFT JOIN C_ElementValue ev ON fact_acct.account_id = ev.C_ElementValue_id
	LEFT JOIN GL_Journal jou ON fact_acct.record_id = jou.GL_journal_id AND fact_acct.ad_table_id = 224
	 LEFT JOIN C_invoice inv ON fact_acct.record_id = inv.c_invoice_id AND  fact_acct.ad_table_id = 318
	 LEFT JOIN M_inout inout ON fact_acct.record_id = inout.M_inout_id AND fact_acct.ad_table_id = 319
	 LEFT JOIN M_inventory tory ON fact_acct.record_id = tory.M_inventory_id AND fact_acct.ad_table_id = 321
	 LEFT JOIN M_Movement mov ON fact_acct.record_id = mov.M_movement_id AND fact_acct.ad_table_id = 323 
	 LEFT JOIN M_Production prod ON fact_acct.record_id = prod.M_Production_id AND fact_acct.ad_table_id = 325
	 LEFT JOIN C_payment pay ON fact_acct.record_id = pay.c_payment_id AND fact_acct.ad_table_id = 335
	 LEFT JOIN M_Matchinv match ON fact_acct.record_id = match.M_Matchinv_id AND fact_acct.ad_table_id = 472
	 LEFT JOIN C_allocationhdr hdr ON fact_acct.record_id	= hdr.C_allocationhdr_id AND fact_acct.ad_table_id = 735
     LEFT OUTER JOIN C_ElementValue ev1 ON ev1.C_ElementValue_id = $P{Account_ID} 
          LEFT OUTER JOIN C_ElementValue ev2 ON ev2.C_ElementValue_id = $P{AccountTo_ID} 
WHERE
     fact_acct.ad_client_id = $P{AD_CLIENT_ID} 
     AND fact_acct.ad_org_id =  $P{AD_Org_ID} 
    AND fact_acct."dateacct" >=   $P{DateAcctFrom}
	AND fact_acct."dateacct" <=  $P{DateAcctTo}
AND 	CASE
	when  $P{Account_ID} is not Null  AND  $P{AccountTo_ID} IS NULL
	then fact_acct.account_id =  $P{Account_ID}
	when  $P{Account_ID}  is not null AND  $P{AccountTo_ID} is not null
	then ev.value >=  ev1.value  AND ev.value<= ev2.value
	else 1=1 END
	
	AND fact_acct.postingtype = 'A'
   order by  ev.value,   fact_acct."dateacct" ,  fact_acct."seqno"]]>
	</queryString>
