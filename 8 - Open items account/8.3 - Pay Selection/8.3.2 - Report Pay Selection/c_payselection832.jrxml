	<queryString>
		<![CDATA[WITH ach_bank AS (
  SELECT DISTINCT ON (c_bpartner_id)
    c_bpartner_id,
    C_Bank_ID
  FROM C_BP_BankAccount
  WHERE isach = 'Y'
  ORDER BY c_bpartner_id, updated DESC
)
select
	coalesce(org.description, ORG.NAME) as orgName,
	ps.name as c_payselection_name,
	ps.description as c_payselection_description,
	ps.totalamt as c_payselection_totalamt,
	bkacc.iban as c_bankaccount_iban,
	orgloc.Address1 as orglocAddress1,
	orgloc.Postal as orglocPostal,
	orgloc.City as orglocCity,
	orginfo.Phone as orginfoPhone,
	orginfo.Fax as orginfoFax,
	bp.Name as bpName,
	inv.DateInvoiced,
	inv.DocumentNo,
	psl.PayAmt,
	ps.paydate,
	bank.Name as bankName,
	coalesce(bank.Description, '') as bankDescription,
	coalesce(business_partner_bank.name,business_partner_bank.description) as Banca_BP,
	business_partner_bank.RoutingNo,
	c_currency.iso_code,
	ips.duedate
from
	C_PaySelection PS
inner join C_PaySelectionLine PSL on
	PS.C_PaySelection_ID = PSL.C_PaySelection_ID
inner join C_Invoice INV on
	INV.c_invoice_id = PSL.c_invoice_id
LEFT JOIN ach_bank BA ON BA.c_bpartner_id = INV.c_bpartner_id
LEFT JOIN C_Bank business_partner_bank
  ON business_partner_bank.C_Bank_ID = BA.C_Bank_ID
inner join c_currency on
	inv.c_currency_id = c_currency.c_currency_id
inner join C_BPartner BP on
	INV.c_bpartner_id = BP.c_bpartner_id
inner join AD_Org org on
	org.AD_Org_ID = inv.AD_Org_ID
inner join AD_OrgInfo orginfo on
	orginfo.AD_Org_ID = inv.AD_Org_ID
inner join C_Location orgloc on
	orgloc.C_Location_ID = orginfo.C_Location_ID
left join C_BankAccount bkacc on
	bkacc.C_BankAccount_ID = ps.c_bankaccount_id
	-- bank.C_Bank_ID AND bkacc.IsDefault = 'Y'
left join C_Bank bank on
	bank.C_Bank_ID = bkacc.C_Bank_ID
left join c_invoicepayschedule ips on
	psl.c_invoicepayschedule_id = ips.c_invoicepayschedule_id
where
	ps.c_payselection_id = $P{RECORD_ID}
order by
	bp.name
	
	]]>
	</queryString>
