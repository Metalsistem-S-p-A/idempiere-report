	<parameter name="RECORD_ID" class="java.lang.Integer"/>
	<parameter name="LOCALE_CODE" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[$P{REPORT_LOCALE}.toString()]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT 
lit_adorg_header_landscape_image(f.ad_client_id, f.ad_org_id ),
	 lit_adorg_footer_landscape_image(f.ad_client_id, f.ad_org_id ),
	 lit_date_pattern($P{LOCALE_CODE}) AS datepattern,
	 lit_datetime_pattern($P{LOCALE_CODE}) AS datetimepattern,
gj.AD_Org_ID,
	F.DATEACCT,
F.DATETRX ,
GJ.DOCUMENTNO ,
GJ.Description,
F.AMTACCTDR,
F.AMTACCTCR ,
F.SEQNO ,
EV.VALUE AS ElementValue,
EV.NAME AS ElementName,
GJ.TotalDr,
Gj.TotalCr,
c_currency.iso_code
FROM FACT_ACCT F
inner join c_currency on f.c_currency_id = c_currency.c_currency_id
INNER JOIN C_ELEMENTVALUE EV    ON (F.ACCOUNT_ID = EV.C_ELEMENTVALUE_ID)
LEFT JOIN GL_JOURNAL GJ         ON (F.AD_TABLE_ID=224 AND F.RECORD_ID=GJ.GL_JOURNAL_ID)
WHERE 
 F.POSTINGTYPE = 'A' AND 
GJ.GL_JOURNAL_ID= $P{RECORD_ID}
ORDER BY ElementValue]]>
	</queryString>
